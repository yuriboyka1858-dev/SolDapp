{
  "rewrites": [
    {
      "source": "/api/jupiter/quote",
      "destination": "https://public.jupiterapi.com/quote"
    },
    {
      "source": "/api/jupiter/swap",
      "destination": "https://public.jupiterapi.com/swap"
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "header",
          "key": "x-vercel-ip-country",
          "value": "(CU|IR|KP|SY)"
        }
      ],
      "destination": "https://www.treasury.gov/resource-center/sanctions/",
      "permanent": false
    }
  ]
}
